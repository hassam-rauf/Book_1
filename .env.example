# ============================================================
# Physical AI Textbook — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Gemini (LLM + Embeddings) ───────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Qdrant Cloud (Vector Database) ──────────────────────────
# Get from: https://cloud.qdrant.io → Cluster → API Keys
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=physical-ai-book

# ── Neon Postgres (SQL Database) ────────────────────────────
# Get from: https://console.neon.tech → Connection String
DATABASE_URL=postgres://user:password@your-project.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Backend Server ───────────────────────────────────────────
PORT=8000

# ── CORS (comma-separated allowed origins) ──────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://hassam-rauf.github.io

# ── Docusaurus Docs Directory (used by ingest.py) ───────────
# Relative path from backend/ to the docs folder
DOCS_DIR=../book-site/docs

# ── Auth Service (F6 — auth-service/.env has its own copy) ──
# URL of the Node.js/Hono auth-service (used by Docusaurus frontend)
AUTH_SERVICE_URL=http://localhost:3001

# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-32-char-random-secret-here
