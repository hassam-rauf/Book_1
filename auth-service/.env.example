# Neon Postgres connection string — WebSocket Pool mode required (NOT HTTP driver)
# Get from: https://console.neon.tech/ → Connection Details → Connection string
DATABASE_URL=postgres://user:pass@your-project.neon.tech/neondb?sslmode=require

# better-auth secret — must be 32+ characters
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=your-32-char-random-secret-here

# URL of this auth-service (used by better-auth for cookie domain)
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated origins allowed for CORS (Docusaurus dev + GitHub Pages)
ALLOWED_ORIGINS=http://localhost:3000,https://hassam-rauf.github.io

# Port to listen on (default: 3001)
PORT=3001
